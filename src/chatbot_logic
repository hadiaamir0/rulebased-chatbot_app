"""
chatbot_logic.py

Core logic for the rule-based chatbot: knowledge base and response lookup.
Kept separate from the UI layer (chatbot.py / chatbot_app.py) so the same
logic can power both the terminal version and the Streamlit web version.
"""

# Knowledge base: maps recognized intents (lowercase, stripped) to responses
RESPONSES = {
    "hello": "Hi there! How can I help you today?",
    "hi": "Hey! What can I do for you?",
    "how are you": "I'm just a bunch of if-else statements, but I'm doing great!",
    "what is your name": "I'm a rule-based chatbot built for DecodeLabs Project 1.",
    "what can you do": "I can respond to a few predefined commands. Try 'help'!",
    "help": "Available commands: hello, how are you, what is your name, what can you do, bye/exit",
    "thank you": "You're welcome!",
    "thanks": "Anytime!",
}

# Recognized commands that end the conversation
EXIT_COMMANDS = {"bye", "exit", "quit"}

DEFAULT_REPLY = "I do not understand. Type 'help' for options."
EXIT_REPLY = "Goodbye! Have a great day."


def clean_text(text: str) -> str:
    """Normalize user input: lowercase and strip surrounding whitespace."""
    return text.lower().strip()


def is_exit_command(text: str) -> bool:
    """Check whether the (already cleaned) input should end the chat."""
    return clean_text(text) in EXIT_COMMANDS


def get_response(user_input: str) -> str:
    """
    Look up a response for the given user input.

    Returns the matching reply from RESPONSES, EXIT_REPLY if the input is
    an exit command, or DEFAULT_REPLY if no rule matches.
    """
    clean_input = clean_text(user_input)

    if clean_input in EXIT_COMMANDS:
        return EXIT_REPLY

    return RESPONSES.get(clean_input, DEFAULT_REPLY)
